<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="ugv_bot">

  <xacro:property name="PI" value="3.14159265359"/>

  <xacro:property name="a" value="0.6"/>
  <xacro:property name="b" value="0.4"/>
  <xacro:property name="c" value="0.2"/> 
  <xacro:property name="r" value="0.1"/> 
  <xacro:property name="d" value="0.05"/> 
  <xacro:property name="s1" value="0.0"/>
  <xacro:property name="s2" value="0.2"/> 
  <xacro:property name="s3" value="0.2"/> 
  <xacro:property name="s4" value="0.25"/> 
  <xacro:property name="d1" value="2700.0"/>
  <xacro:property name="d2" value="2700.0"/> 
  <xacro:property name="d3" value="2700.0"/> 

  <xacro:property name="m1" value="${d1 * a * b * c}"/>
  <xacro:property name="m2" value="${d2 * PI * r* r * d}"/>
  <xacro:property name="m3" value="${d3 * (4.0/3.0) * PI * r * r * r}"/>

  <xacro:property name="Ix_body" value="${(1/12)*m1*(b*b+c*c)}"/>
  <xacro:property name="Iy_body" value="${(1/12)*m1*(a*a+c*c)}"/>
  <xacro:property name="Iz_body" value="${(1/12)*m1*(a*a+b*b)}"/>

  <xacro:property name="Iz_wheel" value="${0.5*m2*r*r}"/>
  <xacro:property name="I_wheel" value="${(1.0/12.0)*m2*(3*r*r+d*d)}" />

  <xacro:property name="I_caster" value="${(2.0/5.0)*m3*r*r}" />

  <xacro:macro name="inertia_body">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 ${s1}" />
      <mass value="${m1}"/>
      <inertia ixx="${Ix_body}" ixy="0.0" ixz="0.0" 
               iyy="${Iy_body}" iyz="0.0" 
               izz="${Iz_body}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="inertia_wheel" params="mass">
    <inertial>
      <origin rpy="1.570795 0 0" xyz="0 0 0"/>
      <mass value="${mass}"/>
      <inertia ixx="${I_wheel}" ixy="0.0" ixz="0.0" 
               iyy="${I_wheel}" iyz="0.0" 
               izz="${Iz_wheel}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="inertia_caster" params="mass r">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="${mass}"/>
      <inertia ixx="${I_caster}" ixy="0.0" ixz="0.0" 
               iyy="${I_caster}" iyz="0.0" 
               izz="${I_caster}"/>
    </inertial>
  </xacro:macro>

  <xacro:include filename="$(find ugv_bot)/model/robot.gazebo"/>

  <link name="base_footprint"/>

  <joint name="body_link_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="body_link"/>
    <origin xyz="0 0 ${r + 0.02}" rpy="0 0 0"/>
  </joint>

  <link name="body_link">
    <visual>
      <origin xyz="0 0 ${s1}" rpy="0 0 0"/>
      <geometry>
        <box size="${a} ${b} ${c}"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 ${s1}" rpy="0 0 0"/>
      <geometry>
        <box size="${a} ${b} ${c}"/>
      </geometry>
    </collision>
    <xacro:inertia_body />
  </link>

  <joint name="wheel_1_joint" type="continuous">
    <parent link="body_link"/>
    <child link="wheel_1_link"/>
    <origin xyz="-${s2} -${s4} -0.02" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="50000" velocity="10"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <link name="wheel_1_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.570795 0 0"/>
      <geometry>
        <cylinder length="${d}" radius="${r}"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.570795 0 0"/>
      <geometry>
        <cylinder length="${d}" radius="${r}"/>
      </geometry>
    </collision>
    <xacro:inertia_wheel mass="${m2}" />
  </link>

  <joint name="wheel_2_joint" type="continuous">
    <parent link="body_link"/>
    <child link="wheel_2_link"/>
    <origin xyz="-${s2} ${s4} -0.02" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="50000" velocity="10"/>
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <link name="wheel_2_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.570795 0 0"/>
      <geometry>
        <cylinder length="${d}" radius="${r}"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.570795 0 0"/>
      <geometry>
        <cylinder length="${d}" radius="${r}"/>
      </geometry>
    </collision>
    <xacro:inertia_wheel mass="${m2}"/>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="body_link"/>
    <child link="caster_link"/>
    <origin xyz="${s3} 0 -0.02" rpy="0 0 0"/>
  </joint>

  <link name="caster_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${r}"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${r}"/>
      </geometry>
    </collision>
    <xacro:inertia_caster mass="${m3}" r="${r}"/>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="body_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 ${c/2 + 0.05}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.1" radius="0.1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.1" radius="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

</robot>